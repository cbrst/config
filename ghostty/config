# Split config
config-file = ?keybindings

# Shell integration
shell-integration-features = ssh-env,ssh-terminfo

# Font
font-family = ""
# font-family = "LigSFMono Nerd Font"
font-family = "CommitMono"
font-size = 12
# This font includes Powerline/Nerd Font glyphs, so zsh can use the full prompt.
env = CONFIG_POWERLINE_GLYPHS=1
adjust-cursor-thickness = 2

# adjustments for SFMono
# increase the line height and center the text
adjust-cell-height = 20%
adjust-font-baseline = 20%

# Theme
# theme = light:catppuccin-latte,dark:catppuccin-mocha
config-file = ?theme
# theme = catppuccin-mocha
unfocused-split-opacity = 0.5

# Mouse
mouse-hide-while-typing = true

# Window
background-blur-radius = 32
window-colorspace = display-p3
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-padding-color = extend
window-theme = ghostty

# Mac
macos-titlebar-style = tabs
macos-icon = xray
macos-icon-frame = aluminum

# GTK
gtk-titlebar = true

# Updating
auto-update = download

# Machine-specific configs
config-file = ?machine

